# Blueprint POC - Environment Variables

# ============================================================================
# REQUIRED - OpenAI API
# ============================================================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE

# ============================================================================
# AWS Configuration (for ECR push and AgentCore deployment)
# ============================================================================
# Your AWS account ID (required for Bedrock tool init and deployment)
AWS_ACCOUNT_ID=YOUR_AWS_ACCOUNT_ID

# AWS region (us-east-1 recommended)
AWS_DEFAULT_REGION=us-east-1

# AWS access keys (optional - can use AWS CLI configured credentials instead)
# AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY
# AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY

# ============================================================================
# Optional - Server Configuration
# ============================================================================
# Shared secret for X-API-Key on /agents and /chat/* (browser UI loads this from /app-api-config.js)
APP_API_KEY=your-app-api-key-here

# Host to bind the API server to
API_HOST=0.0.0.0

# Port to run the API server on
API_PORT=8000

# Enable debug mode
DEBUG=False

# ============================================================================
# Optional - Logging
# ============================================================================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================================================
# Optional - Database (for future use)
# ============================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/blueprint_poc
# REDIS_URL=redis://localhost:6379

# ============================================================================
# Optional - Docker Configuration
# ============================================================================
# Docker registry (for ECR push)
DOCKER_REGISTRY=YOUR_AWS_ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com

# ============================================================================
# Optional - Feature Flags
# ============================================================================
# Enable auto-suggest tools
AUTO_SUGGEST_TOOLS=true

# Enable memory in workflows by default
INCLUDE_MEMORY=true

# Enable knowledge base in workflows by default
INCLUDE_KNOWLEDGE_BASE=true
